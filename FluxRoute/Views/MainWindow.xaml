                        </Border>

                        <!-- ╔══════════ TAB 8: ЛОГИ ══════════╗ -->
                        <Border d:IsLocked="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="8">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="16,12" d:IsLocked="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#111520" BorderBrush="#1E2235" BorderThickness="1"
                                    CornerRadius="10" Padding="12" Margin="0,0,0,10" d:IsLocked="True">
                                    <StackPanel d:IsLocked="True">
                                        <TextBlock Text="Логи" Foreground="#4A90E2" FontSize="14" FontWeight="Bold" Margin="0,0,0,4" d:IsLocked="True"/>
                                        <TextBlock Text="События приложения, оркестратора, winws.exe, TG WS Proxy, обновлений и сервиса."
                                               Foreground="#4A5170" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10" d:IsLocked="True"/>
                                        <WrapPanel VerticalAlignment="Center" d:IsLocked="True">
                                            <TextBlock Text="Тип:" Foreground="#4A5170" VerticalAlignment="Center" Margin="0,0,6,0" d:IsLocked="True"/>
                                            <ComboBox Width="200" Height="28" Margin="0,0,10,6"
                                                  ItemsSource="{Binding LogCategoryFilters}"
                                                  SelectedItem="{Binding SelectedLogCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" d:IsLocked="True"/>
                                            <TextBlock Text="Поиск:" Foreground="#4A5170" VerticalAlignment="Center" Margin="0,0,6,0" d:IsLocked="True"/>
                                            <TextBox Width="200" Height="28" Margin="0,0,10,6" VerticalContentAlignment="Center"
                                                 Text="{Binding LogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" d:IsLocked="True"/>
                                            <CheckBox Content="Только ошибки" Foreground="#9BB0D0" Margin="0,4,12,6"
                                                  VerticalAlignment="Center" IsChecked="{Binding LogsErrorsOnly, Mode=TwoWay}" d:IsLocked="True"/>
                                            <CheckBox Content="Автопрокрутка" Foreground="#9BB0D0" Margin="0,4,12,6"
                                                  VerticalAlignment="Center" IsChecked="{Binding LogsAutoScroll, Mode=TwoWay}" d:IsLocked="True"/>
                                            <Button Content="Очистить"   Style="{StaticResource ActionBtn}" Height="28" Padding="10,0" Margin="0,0,6,6" Command="{Binding ClearUnifiedLogsCommand}" d:IsLocked="True"/>
                                            <Button Content="Скопировать" Style="{StaticResource ActionBtn}" Height="28" Padding="10,0" Margin="0,0,6,6" Command="{Binding CopyUnifiedLogsCommand}" d:IsLocked="True"/>
                                            <Button Content="Сохранить"  Style="{StaticResource ActionBtn}" Height="28" Padding="10,0" Margin="0,0,6,6" Command="{Binding SaveUnifiedLogsCommand}" d:IsLocked="True"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Background="#080B12" BorderBrush="#1E2235" BorderThickness="1" CornerRadius="8" d:IsLocked="True">
                                    <TextBox x:Name="UnifiedLogsTextBox"
                                         Background="Transparent" Foreground="#9BB0D0" BorderThickness="0"
                                         FontFamily="Consolas" FontSize="12" Padding="10,8" IsReadOnly="True" IsUndoEnabled="False"
                                         AcceptsReturn="True" TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                         Text="{Binding UnifiedLogsText, Mode=OneWay}" d:IsLocked="True"/>
                                </Border>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Border>
</Window>
