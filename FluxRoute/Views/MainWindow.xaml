                                        <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3" d:IsLocked="True">
                                        <Run Text="• "/>
                                        <Hyperlink NavigateUri="https://github.com/klondike0x" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">klondike0x</Hyperlink>
