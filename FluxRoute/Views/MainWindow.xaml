                                            <TextBlock Text="⬇️ Первый запуск — скачиваем Flowseal..." FontFamily="Segoe UI"
                                                       Foreground="#FFD700" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4" d:IsLocked="True"/>
                                            <TextBlock Text="{Binding EngineDownloadStatus}" FontFamily="Segoe UI"
                                                       Foreground="#CCAA00" FontSize="11" TextWrapping="Wrap" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- STATUS + PROFILE row -->
                                    <Grid Margin="0,0,0,12" d:IsLocked="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status card -->
                                        <Border Grid.Column="0" Style="{StaticResource Card}" d:IsLocked="True">
                                            <StackPanel d:IsLocked="True">
                                                <TextBlock Text="Статус" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,8" d:IsLocked="True"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4" d:IsLocked="True">
                                                    <TextBlock FontFamily="Segoe UI" FontSize="13" Margin="0,0,6,0" d:IsLocked="True">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="○"/>
                                                                <Setter Property="Foreground" Value="#F85149"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <Setter Property="Text" Value="●"/>
                                                                        <Setter Property="Foreground" Value="#3FB950"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontFamily="Segoe UI" FontSize="13" d:IsLocked="True">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="Защита не активна"/>
                                                                <Setter Property="Foreground" Value="#F85149"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                        <Setter Property="Text" Value="Защита активна"/>
                                                                        <Setter Property="Foreground" Value="#3FB950"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                                <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0" d:IsLocked="True">
                                                    <Run Text="PID: "/><Run Text="{Binding PidText, Mode=OneWay}" Foreground="#E6EDF3"/>
                                                </TextBlock>
                                                <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" d:IsLocked="True">
                                                    <Run Text="Uptime: "/><Run Text="{Binding UptimeText, Mode=OneWay}" Foreground="#E6EDF3"/>
                                                </TextBlock>
                                            </StackPanel>
