                                                        FontSize="12" Padding="8,4"
                                                        Command="{Binding OpenEngineFolderCommand}"
                                                        ToolTip="Открыть папку с движком"
                                                        AutomationProperties.Name="Открыть папку с движком"
                                                        HorizontalAlignment="Left" Margin="0,0,0,4" d:IsLocked="True"/>
                                                <Button Content="Показать логи" Visibility="Collapsed" Style="{StaticResource TermBtn}"
                                                        FontSize="12" Padding="8,4"
                                                        Command="{Binding ShowLogsCommand}"
                                                        HorizontalAlignment="Left" Margin="0,0,0,4" d:IsLocked="True"/>
