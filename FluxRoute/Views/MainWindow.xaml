<Window x:Class="FluxRoute.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:conv="clr-namespace:FluxRoute.Converters"
        mc:Ignorable="d"
        Title="FluxRoute"
        Height="520" Width="860"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanConverter x:Key="InvBool"/>
        <conv:BoolToInstalledConverter x:Key="BoolToInstalled"/>

        <!-- ══ COLORS ══ -->
        <SolidColorBrush x:Key="BgMain"     Color="#0D0F1A"/>
        <SolidColorBrush x:Key="BgSidebar"  Color="#080A12"/>
        <SolidColorBrush x:Key="BgCard"     Color="#0E1120"/>
        <SolidColorBrush x:Key="BgCardAlt"  Color="#0B0D18"/>
        <SolidColorBrush x:Key="BorderDim"  Color="#1A1E30"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#55AAFF"/>
        <SolidColorBrush x:Key="AccentPurple" Color="#9933DD"/>
        <SolidColorBrush x:Key="AccentGreen" Color="#00D68F"/>
        <SolidColorBrush x:Key="TextPrimary" Color="#DDE4F5"/>
        <SolidColorBrush x:Key="TextMuted"   Color="#3D4260"/>

        <!-- ══ TOGGLE SWITCH STYLE ══ -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border Width="44" Height="24" CornerRadius="12" x:Name="Track" Background="#1A1D2C">
                            <Ellipse x:Name="Thumb" Width="18" Height="18" VerticalAlignment="Center"
                                     HorizontalAlignment="Left" Margin="3,0,0,0">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="#4A5170"/>
                                </Ellipse.Fill>
                                <Ellipse.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#1A2E66"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="#55AAFF"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="20" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.15">
                                                <DoubleAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ NAV ACTIVE BACKGROUND ══ -->
        <LinearGradientBrush x:Key="NavActiveBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#CC4B3FAA" Offset="0"/>
            <GradientStop Color="#AA6630DD" Offset="1"/>
        </LinearGradientBrush>

        <!-- ══ NAV ICON BUTTON ══ -->
        <Style x:Key="NavIconBtn" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Width" Value="52"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="8" Margin="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard Name="HoverEnterSB">
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.12" Duration="0:0:0.15" FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.12" Duration="0:0:0.15" FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="HoverEnterSB"/>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                             To="1.0" Duration="0:0:0.2" FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                             To="1.0" Duration="0:0:0.2" FillBehavior="HoldEnd">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                         To="0.88" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                         To="0.88" Duration="0:0:0.08">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Button.PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                         To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                         To="1.0" Duration="0:0:0.15">
                                            <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ TITLEBAR BUTTON ══ -->
        <Style x:Key="TitleBtn" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A2040"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CloseTitleBtn" TargetType="Button" BasedOn="{StaticResource TitleBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C0392B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ ACTION BUTTON ══ -->
        <Style x:Key="ActionBtn" TargetType="Button">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#9BB0D0"/>
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value><ScaleTransform ScaleX="1" ScaleY="1"/></Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="6" x:Name="Bd">
                            <Border.Background><SolidColorBrush x:Name="BdBg" Color="#111520"/></Border.Background>
                            <Border.BorderBrush><SolidColorBrush x:Name="BdBorder" Color="#1E2235"/></Border.BorderBrush>
                            <Border.BorderThickness><Thickness>1</Thickness></Border.BorderThickness>
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="Border.MouseEnter" SourceName="Bd">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BdBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#4A90E2" Duration="0:0:0.18">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="BdBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#161C2E" Duration="0:0:0.18">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="Border.MouseLeave" SourceName="Bd">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="BdBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#1E2235" Duration="0:0:0.22">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                        <ColorAnimation Storyboard.TargetName="BdBg"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#111520" Duration="0:0:0.22">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.95" ScaleY="0.95"/></Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionBtnGreen" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#00D68F"/>
            <Setter Property="BorderBrush" Value="#004D3A"/>
        </Style>
        <Style x:Key="ActionBtnRed" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#E74C3C"/>
            <Setter Property="BorderBrush" Value="#6B1A1A"/>
        </Style>
        <Style x:Key="ActionBtnAccent" TargetType="Button" BasedOn="{StaticResource ActionBtn}">
            <Setter Property="Foreground" Value="#4A90E2"/>
            <Setter Property="BorderBrush" Value="#1E3A7A"/>
        </Style>

        <!-- ══ LEGACY ALIASES (backward compat) ══ -->
        <Style x:Key="TermBtn"   TargetType="Button" BasedOn="{StaticResource ActionBtn}"/>
        <Style x:Key="AccentBtn" TargetType="Button" BasedOn="{StaticResource ActionBtnAccent}"/>
        <Style x:Key="GreenBtn"  TargetType="Button" BasedOn="{StaticResource ActionBtnGreen}"/>
        <Style x:Key="RedBtn"    TargetType="Button" BasedOn="{StaticResource ActionBtnRed}"/>

        <!-- ══ SECTION HEADER ══ -->
        <Style x:Key="SecH" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#4A90E2"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,14,0,8"/>
            <Setter Property="Margin" Value="0,14,0,8"/>
        </Style>

        <!-- ══ LABEL / VALUE ══ -->
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#4A5170"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="Val" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- ══ CARD ══ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="14,12"/>
        </Style>

        <!-- ══ LOG AREA ══ -->
        <Style x:Key="LogArea" TargetType="Border">
            <Setter Property="Background" Value="#080B12"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="MaxHeight" Value="150"/>
        </Style>

        <!-- ══ SEPARATOR ══ -->
        <Style x:Key="Sep" TargetType="Rectangle">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Fill" Value="#1E2235"/>
            <Setter Property="Margin" Value="0,8"/>
        </Style>

        <!-- ══ COMBOBOX ══ -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="8,0,0,0" VerticalAlignment="Center">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="#C8D4EC"/>
                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                <Setter Property="FontSize" Value="12"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#4A5170"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="11"/>
                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                  Background="Transparent" BorderThickness="0"
                                                  Cursor="Hand" Opacity="0"/>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   Placement="Bottom" PopupAnimation="Slide">
                                <Border Background="#111520" BorderBrush="#1E2235"
                                        BorderThickness="1" CornerRadius="6" Margin="0,2,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#161C2E"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ══ CHECKBOX ══ -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#4A5170"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- ══ TEXTBOX ══ -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#111520"/>
            <Setter Property="Foreground" Value="#C8D4EC"/>
            <Setter Property="BorderBrush" Value="#1E2235"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="CaretBrush" Value="#C8D4EC"/>
            <Setter Property="SelectionBrush" Value="#3355AAFF"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <Border.BorderBrush><SolidColorBrush x:Name="RootBorder" Color="#1E2235"/></Border.BorderBrush>
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="UIElement.GotFocus">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="RootBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#55AAFF" Duration="0:0:0.18">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="UIElement.LostFocus">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="RootBorder"
                                                        Storyboard.TargetProperty="Color"
                                                        To="#1E2235" Duration="0:0:0.22">
                                            <ColorAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></ColorAnimation.EasingFunction>
                                        </ColorAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="AcceptsReturn" Value="True">
                    <Setter Property="VerticalContentAlignment" Value="Top"/>
                    <Setter Property="Padding" Value="6,6"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ══ NAV ACTIVE BG ══ -->
        <Style x:Key="NavActiveHighlight" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Margin" Value="6,2"/>
        </Style>
    </Window.Resources>

    <!-- ROOT -->
    <Border Background="#0c0f17" BorderBrush="#1C1F2E" BorderThickness="1" CornerRadius="12" ClipToBounds="True" d:IsLocked="True">
        <Grid d:IsLocked="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ═══════════ TITLE BAR ═══════════ -->
            <Border Grid.Row="0" Background="#0C0F17" CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="Header_MouseLeftButtonDown" d:IsLocked="True">
                <Grid Margin="12,0" d:IsLocked="True">
                    <!-- Logo mark -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" d:IsLocked="True">
                        <Image Source="pack://application:,,,/FluxRoute;component/Resources/FluxRoute.png"
                               Width="22" Height="22" Margin="0,0,9,0"
                               RenderOptions.BitmapScalingMode="HighQuality" d:IsLocked="True"/>
                        <TextBlock VerticalAlignment="Center" FontFamily="Segoe UI" FontSize="13" d:IsLocked="True">
                            <Run Text="FluxRoute" FontWeight="SemiBold" Foreground="#C8D4EC"/>
                            <Run Text=" v" Foreground="#C8D4EC" FontWeight="SemiBold"/><Run Text="{Binding AppVersion, Mode=OneWay}" Foreground="#C8D4EC" FontWeight="SemiBold"/>
                            <Run Text=" by klondike0x" Foreground="#3D4260" FontWeight="Normal"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- Window controls -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,-2,0" d:IsLocked="True">
                        <Button Style="{StaticResource TitleBtn}" Click="MinimizeButton_Click" d:IsLocked="True">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#4A5170" d:IsLocked="True"/>
                        </Button>
                        <Button Style="{StaticResource CloseTitleBtn}" Click="CloseButton_Click" d:IsLocked="True">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="9" Foreground="#4A5170" d:IsLocked="True"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══════════ BODY ═══════════ -->
            <Grid Grid.Row="1" Margin="0,0,10,10" d:IsLocked="True">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="0*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="66"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ─── SIDEBAR ─── -->
                <Border Grid.Column="0" x:Name="SidebarBorder" Background="#0C0F17"
                        BorderThickness="0" d:IsLocked="True">
                    <!-- Gradient separator right edge -->
                    <Grid d:IsLocked="True">
