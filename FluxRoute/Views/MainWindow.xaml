                                        <Run Text="• "/>
                                        <Hyperlink NavigateUri="https://github.com/basil00/WinDivert" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">WinDivert</Hyperlink>
                                        <Run Text=" — низкоуровневая основа"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3" d:IsLocked="True">
                                        <Run Text="• "/>
                                        <Hyperlink NavigateUri="https://github.com/bol-van/zapret" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">bol-van/zapret</Hyperlink>
                                        <Run Text=" — оригинальный проект"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3" d:IsLocked="True">
                                        <Run Text="• "/>
                                        <Hyperlink NavigateUri="https://github.com/Flowseal/zapret-discord-youtube" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">Flowseal/zapret-discord-youtube</Hyperlink>
                                        <Run Text=" — основа engine"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource SecH}" Text="ПОЛЕЗНЫЕ ССЫЛКИ" d:IsLocked="True"/>
                                    <StackPanel Margin="8,0,0,0" d:IsLocked="True">
                                        <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3" d:IsLocked="True">
                                        <Run Text="• "/>
                                        <Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">FluxRoute на GitHub</Hyperlink>
                                        <Run Text=" — репозиторий проекта"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#9BB0D0" FontSize="12" Margin="0,3" d:IsLocked="True">
                                        <Run Text="• "/>
                                        <Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute/releases" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4A90E2">Релизы</Hyperlink>
                                        <Run Text=" — скачать последнюю версию"/>
