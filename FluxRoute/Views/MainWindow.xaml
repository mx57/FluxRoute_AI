                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Diagnostics card -->
                                        <Border Grid.Column="0" Style="{StaticResource Card}" d:IsLocked="True">
                                            <StackPanel d:IsLocked="True">
                                                <TextBlock Text="Диагностика" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,8" d:IsLocked="True"/>
