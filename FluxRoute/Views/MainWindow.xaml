                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="3">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" d:IsLocked="True">
                                <StackPanel Margin="16,12" d:IsLocked="True">
                                    <TextBlock Style="{StaticResource SecH}" Text="РЕЖИМ ИИ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <CheckBox Content="Включить самообучаемый подбор стратегий (оркестратор использует ИИ)"
                                              IsChecked="{Binding AiEnabled}" Margin="0,0,0,10" d:IsLocked="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" d:IsLocked="True">
                                        <TextBlock Style="{StaticResource Lbl}" Text="Exploration (‰): " VerticalAlignment="Center" Margin="0,0,8,0" d:IsLocked="True"/>
                                        <TextBox Text="{Binding AiExplorationPermil, UpdateSourceTrigger=PropertyChanged}"
                                                 Width="60" Height="26" VerticalContentAlignment="Center" d:IsLocked="True"/>
                                    </StackPanel>
                                    <Grid Margin="0,0,0,12" d:IsLocked="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource Lbl}" Text="Сеть:" d:IsLocked="True"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding AiNetworkLabel}" d:IsLocked="True"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource Lbl}" Text="Поколение:" d:IsLocked="True"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding AiGenerationText}" d:IsLocked="True"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource Lbl}" Text="Проб в истории:" d:IsLocked="True"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource Val}" Text="{Binding AiProbeCountText}" d:IsLocked="True"/>
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" d:IsLocked="True">
                                        <Button Content="⚗ Эволюция сейчас" Style="{StaticResource AccentBtn}"
                                                Margin="0,0,10,0" Command="{Binding RunAiEvolutionCommand}" d:IsLocked="True"/>
                                        <Button Content="↺ Сброс модели" Style="{StaticResource TermBtn}"
                                                Margin="0,0,10,0" Command="{Binding ResetAiModelCommand}" d:IsLocked="True"/>
                                        <Button Content="📁 ai-evolved" Style="{StaticResource TermBtn}"
                                                Command="{Binding OpenAiEvolvedFolderCommand}" d:IsLocked="True"/>
                                    </StackPanel>
                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" d:IsLocked="True">
                                        <TextBlock Style="{StaticResource SecH}" Text="СТРАТЕГИИ" d:IsLocked="True"/>
                                        <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="12,2,0,0"
                                                   Text="{Binding AiStrategyRowCount, StringFormat='({0})'}" d:IsLocked="True"/>
