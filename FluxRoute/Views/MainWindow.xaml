                                            <Ellipse.Stroke>
                                                <LinearGradientBrush StartPoint="1,0" EndPoint="0,1">
                                                    <GradientStop Color="#FF3399" Offset="0"/>
                                                    <GradientStop Color="#9933DD" Offset="0.5"/>
                                                    <GradientStop Color="#55AAFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Ellipse.Stroke>
                                            <Ellipse.Effect><BlurEffect Radius="3"/></Ellipse.Effect>
                                            <Ellipse.RenderTransform>
                                                <ScaleTransform x:Name="WaveRing3Scale" ScaleX="1" ScaleY="1"/>
                                            </Ellipse.RenderTransform>
                                        </Ellipse>

                                        <!-- Sharp crisp ring -->
                                        <Ellipse Width="168" Height="168" StrokeThickness="3.5" d:IsLocked="True">
                                            <Ellipse.Stroke>
                                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                    <GradientStop Color="#55AAFF" Offset="0"/>
                                                    <GradientStop Color="#7755EE" Offset="0.5"/>
                                                    <GradientStop Color="#9933DD" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Ellipse.Stroke>
                                        </Ellipse>

                                        <!-- Inner dark disk -->
                                        <Ellipse Width="152" Height="152" d:IsLocked="True">
                                            <Ellipse.Fill>
                                                <RadialGradientBrush>
                                                    <GradientStop Color="#1A1D2C" Offset="0"/>
                                                    <GradientStop Color="#10121E" Offset="1"/>
                                                </RadialGradientBrush>
                                            </Ellipse.Fill>
                                        </Ellipse>

                                        <!-- Subtle concentric inner outline -->
                                        <Ellipse Width="152" Height="152" StrokeThickness="1" Stroke="#18FFFFFF" d:IsLocked="True"/>

                                        <!-- Power icon button -->
                                        <Button Width="152" Height="152" Command="{Binding ToggleStartStopCommand}" Cursor="Hand" d:IsLocked="True">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="Transparent" x:Name="Bd">
                                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                                            <Viewbox Width="54" Height="54">
                                                                <Canvas Width="24" Height="24">
                                                                    <!-- Arc (300°) -->
                                                                    <Path x:Name="Arc" StrokeThickness="1.5" Fill="Transparent"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                                        <Path.Stroke>
                                                                            <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                                                <GradientStop Color="#55AAFF" Offset="0"/>
                                                                                <GradientStop Color="#9933DD" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Path.Stroke>
                                                                        <Path.Data>
                                                                            <PathGeometry>
                                                                                <PathFigure StartPoint="15.5,5.2" IsClosed="False">
                                                                                    <ArcSegment Point="8.5,5.2" Size="8,8"
                                                                                            SweepDirection="Clockwise" IsLargeArc="True"/>
                                                                                </PathFigure>
                                                                            </PathGeometry>
                                                                        </Path.Data>
                                                                        <Path.Effect>
                                                                            <DropShadowEffect Color="#55AAFF" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                                                                        </Path.Effect>
                                                                    </Path>
                                                                    <!-- Power stem -->
                                                                    <Line x:Name="PowerLine" X1="12" Y1="2.5" X2="12" Y2="8"
                                                                      StrokeThickness="1.5"
                                                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round">
                                                                        <Line.Stroke>
                                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                                <GradientStop Color="#55AAFF" Offset="0"/>
                                                                                <GradientStop Color="#7755EE" Offset="1"/>
                                                                            </LinearGradientBrush>
                                                                        </Line.Stroke>
                                                                        <Line.Effect>
                                                                            <DropShadowEffect Color="#55AAFF" BlurRadius="5" ShadowDepth="0" Opacity="0.8"/>
                                                                        </Line.Effect>
                                                                    </Line>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </StackPanel>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                                        </Trigger>
                                                        <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                            <Setter TargetName="Arc"       Property="Stroke" Value="#00D68F"/>
                                                            <Setter TargetName="PowerLine" Property="Stroke" Value="#00D68F"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>
                                    </Grid>

                                    <!-- Row 1: Status pill -->
                                    <Border Grid.Row="1" HorizontalAlignment="Center"
                                        Background="#0A0D1A" BorderBrush="#1E2440" BorderThickness="1"
                                        CornerRadius="16" Padding="24,7" d:IsLocked="True">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" d:IsLocked="True">
                                            <Ellipse Width="7" Height="7" Margin="0,0,8,0" VerticalAlignment="Center" d:IsLocked="True">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#CC3030"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Fill" Value="#00D68F"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                                <Ellipse.Effect>
                                                    <DropShadowEffect ShadowDepth="0" BlurRadius="5" Color="#00D68F" Opacity="0.6"/>
                                                </Ellipse.Effect>
                                            </Ellipse>
                                            <TextBlock FontFamily="Segoe UI" FontSize="11.5" VerticalAlignment="Center" FontWeight="Medium" d:IsLocked="True">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="Защита не активна"/>
                                                        <Setter Property="Foreground" Value="#506080"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                                <Setter Property="Text" Value="Защита активна"/>
                                                                <Setter Property="Foreground" Value="#00D68F"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <!-- Row 3: Bottom stats strip -->
                                    <Grid Grid.Row="3" Margin="0,0,0,8" d:IsLocked="True">
                                        <!-- Subtle top accent line -->
                                        <Rectangle Height="1" VerticalAlignment="Top"
                                               HorizontalAlignment="Stretch" Margin="0,0,0,0" Opacity="0.5" d:IsLocked="True">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#00000000" Offset="0"/>
                                                    <GradientStop Color="#304A80E2" Offset="0.35"/>
                                                    <GradientStop Color="#308040CC" Offset="0.65"/>
                                                    <GradientStop Color="#00000000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>

                                        <!-- Cards container -->
                                        <Border BorderBrush="#1A1E30"
                                            BorderThickness="1" CornerRadius="14" Margin="0,4,0,0" d:IsLocked="True">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#0E1120" Offset="0"/>
                                                    <GradientStop Color="#0B0E1A" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>

                                            <Grid d:IsLocked="True">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- ── Card: Profile ── -->
                                                <Border Grid.Column="0" CornerRadius="14,0,0,14" Cursor="Hand" d:IsLocked="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#0E1428"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid Margin="14,0" d:IsLocked="True">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Icon badge -->
                                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                                            VerticalAlignment="Center" Margin="0,0,10,0" d:IsLocked="True">
                                                            <Border.Background>
                                                                <RadialGradientBrush>
                                                                    <GradientStop Color="#0E2020" Offset="0"/>
                                                                    <GradientStop Color="#081414" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                            <Border.BorderBrush>
                                                                <SolidColorBrush Color="#00C47A" Opacity="0.25"/>
                                                            </Border.BorderBrush>
                                                            <Border.BorderThickness>1</Border.BorderThickness>
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xEA18;"
                                                                   Foreground="#00C47A"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" d:IsLocked="True">
                                                                <TextBlock.Effect>
                                                                    <DropShadowEffect Color="#00D68F" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                                                </TextBlock.Effect>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- Text -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,0,0" d:IsLocked="True">
                                                            <TextBlock Text="{Binding SelectedScriptName}"
                                                                   FontFamily="Segoe UI" FontSize="11"
                                                                   Foreground="#C0CEEC" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="90" d:IsLocked="True"/>
                                                            <TextBlock Text="Профиль"
                                                                   FontFamily="Segoe UI" FontSize="9.5"
                                                                   Foreground="#2E3C5A" Margin="0,2,0,0" d:IsLocked="True"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Separator -->
                                                <Rectangle Grid.Column="0" Width="1" HorizontalAlignment="Right"
                                                       Margin="0,12" d:IsLocked="True">
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0"/>
                                                            <GradientStop Color="#1E2A44" Offset="0.5"/>
                                                            <GradientStop Color="#00000000" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>

                                                <!-- ── Card: Uptime ── -->
                                                <Border Grid.Column="1" Cursor="Hand" d:IsLocked="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#0E1428"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid HorizontalAlignment="Center" d:IsLocked="True">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Icon badge -->
                                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                                            VerticalAlignment="Center" Margin="0,0,10,0" d:IsLocked="True">
                                                            <Border.Background>
                                                                <RadialGradientBrush>
                                                                    <GradientStop Color="#130E28" Offset="0"/>
                                                                    <GradientStop Color="#0B0818" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                            <Border.BorderBrush>
                                                                <SolidColorBrush Color="#8040CC" Opacity="0.25"/>
                                                            </Border.BorderBrush>
                                                            <Border.BorderThickness>1</Border.BorderThickness>
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE9F5;"
                                                                   Foreground="#8040CC"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" d:IsLocked="True">
                                                                <TextBlock.Effect>
                                                                    <DropShadowEffect Color="#9B5DE5" BlurRadius="10" ShadowDepth="0" Opacity="0.6"/>
                                                                </TextBlock.Effect>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- Text -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" d:IsLocked="True">
                                                            <TextBlock Text="{Binding UptimeText, Mode=OneWay}"
                                                                   FontFamily="Segoe UI" FontSize="11"
                                                                   Foreground="#C0CEEC" FontWeight="SemiBold" d:IsLocked="True"/>
                                                            <TextBlock Text="Uptime"
                                                                   FontFamily="Segoe UI" FontSize="9.5"
                                                                   Foreground="#2E3C5A" Margin="0,2,0,0" d:IsLocked="True"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <!-- Separator -->
                                                <Rectangle Grid.Column="1" Width="1" HorizontalAlignment="Right"
                                                       Margin="0,12" d:IsLocked="True">
                                                    <Rectangle.Fill>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#00000000" Offset="0"/>
                                                            <GradientStop Color="#1E2A44" Offset="0.5"/>
                                                            <GradientStop Color="#00000000" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Rectangle.Fill>
                                                </Rectangle>

                                                <!-- ── Card: PID ── -->
                                                <Border Grid.Column="2" CornerRadius="0,14,14,0" Cursor="Hand" d:IsLocked="True">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#0E1428"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid HorizontalAlignment="Center" d:IsLocked="True">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Icon badge -->
                                                        <Border Grid.Column="0" Width="36" Height="36" CornerRadius="10"
                                                            VerticalAlignment="Center" Margin="0,0,10,0" d:IsLocked="True">
                                                            <Border.Background>
                                                                <RadialGradientBrush>
                                                                    <GradientStop Color="#1C1608" Offset="0"/>
                                                                    <GradientStop Color="#110E06" Offset="1"/>
                                                                </RadialGradientBrush>
                                                            </Border.Background>
                                                            <Border.BorderBrush>
                                                                <SolidColorBrush Color="#D4A020" Opacity="0.25"/>
                                                            </Border.BorderBrush>
                                                            <Border.BorderThickness>1</Border.BorderThickness>
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE945;"
                                                                   Foreground="#D4A020"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" d:IsLocked="True">
                                                                <TextBlock.Effect>
                                                                    <DropShadowEffect Color="#F0B429" BlurRadius="10" ShadowDepth="0" Opacity="0.5"/>
                                                                </TextBlock.Effect>
                                                            </TextBlock>
                                                        </Border>

                                                        <!-- Text -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" d:IsLocked="True">
                                                            <TextBlock Text="{Binding PidText, Mode=OneWay}"
                                                                   FontFamily="Segoe UI" FontSize="11"
                                                                   Foreground="#C0CEEC" FontWeight="SemiBold" d:IsLocked="True"/>
                                                            <TextBlock Text="PID"
                                                                   FontFamily="Segoe UI" FontSize="9.5"
                                                                   Foreground="#2E3C5A" Margin="0,2,0,0" d:IsLocked="True"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>

                                </Grid>

                                <!-- ── RIGHT: Cards ── -->
                                <Grid Grid.Column="2" d:IsLocked="True">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="8"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- Card 1: Profile selector -->
                                    <Border Grid.Row="0" Background="#0E1120" BorderBrush="#1A1E30" BorderThickness="1"
                                        CornerRadius="12" Padding="12,10" d:IsLocked="True">
                                        <Grid d:IsLocked="True">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" FontFamily="Segoe MDL2 Assets" FontSize="13" Text="&#xEC05;"
                                                   Foreground="#4A80CC" VerticalAlignment="Center" Margin="0,0,8,0" d:IsLocked="True"/>

                                            <ComboBox Grid.Column="1"
                                                      ItemsSource="{Binding Profiles}"
                                                      SelectedItem="{Binding SelectedProfile, Mode=TwoWay}"
                                                      Height="26"
                                                      Padding="4,2"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Foreground="#8AA0C8"
                                                      FontFamily="Segoe UI"
                                                      FontSize="12"
                                                      VerticalAlignment="Center">
                                                <ComboBox.Template>
                                                    <ControlTemplate TargetType="ComboBox">
                                                        <Grid>
                                                            <Border x:Name="Bd" Background="Transparent" CornerRadius="6" BorderThickness="0">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="16"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <ContentPresenter Grid.Column="0"
                                                                        Content="{TemplateBinding SelectionBoxItem}"
                                                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                                        VerticalAlignment="Center" Margin="0,0,2,0">
                                                                        <ContentPresenter.Resources>
                                                                            <Style TargetType="TextBlock">
                                                                                <Setter Property="Foreground" Value="#8AA0C8"/>
                                                                                <Setter Property="FontFamily" Value="Segoe UI"/>
                                                                                <Setter Property="FontSize" Value="12"/>
                                                                                <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                                                            </Style>
                                                                        </ContentPresenter.Resources>
                                                                    </ContentPresenter>
                                                                    <TextBlock Grid.Column="1" Text="▾" Foreground="#3A5080"
                                                                               FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                    <ToggleButton Grid.Column="0" Grid.ColumnSpan="2"
                                                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                                  Background="Transparent" BorderThickness="0"
                                                                                  Cursor="Hand" Opacity="0"/>
                                                                </Grid>
                                                            </Border>
                                                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                                                   AllowsTransparency="True" Focusable="False"
                                                                   Placement="Bottom" PopupAnimation="Slide">
                                                                <Border Background="#111828" BorderBrush="#1E2A40"
                                                                        BorderThickness="1" CornerRadius="8" Margin="0,3,0,0"
                                                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                                                    <Border.Effect>
                                                                        <DropShadowEffect Color="#000000" BlurRadius="18" ShadowDepth="4" Opacity="0.5"/>
                                                                    </Border.Effect>
                                                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                                                        <ItemsPresenter/>
                                                                    </ScrollViewer>
                                                                </Border>
                                                            </Popup>
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#0E1830"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ComboBox.Template>
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding DisplayName}"
                                                                   FontFamily="Segoe UI" FontSize="12"
                                                                   Foreground="#C8D4EC" Padding="6,5"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>

                                            <!-- Refresh profiles button -->
                                            <Button Grid.Column="2"
                                                    Command="{Binding LoadProfilesCommand}"
                                                    Width="26" Height="26"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand" ToolTip="Обновить список профилей"
                                                    VerticalAlignment="Center" Margin="6,0,0,0">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="Bg" Background="Transparent" CornerRadius="6">
                                                            <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE72C;"
                                                                       FontSize="13" Foreground="#3A5080"
                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="Bg" Property="Background" Value="#0E1830"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </Grid>
                                    </Border>

                                    <!-- Card 2: Toggles -->
                                    <Border Grid.Row="4" Background="#0E1120" BorderBrush="#1A1E30" BorderThickness="1"
                                        CornerRadius="12" Padding="14,12" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <!-- GameFilter -->
                                            <Grid Margin="0,0,0,11" d:IsLocked="True">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                    Background="#0E1428" BorderBrush="#1A2244" BorderThickness="1" d:IsLocked="True">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xEA18;"
                                                           Foreground="#4A7ECC" HorizontalAlignment="Center" VerticalAlignment="Center" d:IsLocked="True"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="Game Filter" FontFamily="Segoe UI"
                                                       FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0" d:IsLocked="True"/>
                                                <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding GameFilterEnabled, Mode=OneWay}" d:IsLocked="True"/>
                                            </Grid>
                                            <!-- Orchestrator -->
                                            <Grid Margin="0,0,0,11" d:IsLocked="True">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                    Background="#100E28" BorderBrush="#201840" BorderThickness="1" d:IsLocked="True">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE8C8;"
                                                           Foreground="#8040D8" HorizontalAlignment="Center" VerticalAlignment="Center" d:IsLocked="True"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="Оркестратор" FontFamily="Segoe UI"
                                                       FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0" d:IsLocked="True"/>
                                                <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding OrchestratorRunning}" d:IsLocked="True"/>
                                            </Grid>
                                            <!-- AutoStart -->
                                            <Grid d:IsLocked="True">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="26"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Width="22" Height="22" CornerRadius="6"
                                                    Background="#0A1420" BorderBrush="#142030" BorderThickness="1" d:IsLocked="True">
                                                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="12" Text="&#xE909;"
                                                           Foreground="#3A9090" HorizontalAlignment="Center" VerticalAlignment="Center" d:IsLocked="True"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="Автозапуск" FontFamily="Segoe UI"
                                                       FontSize="11.5" Foreground="#8090B8" VerticalAlignment="Center" Margin="8,0,0,0" d:IsLocked="True"/>
                                                <CheckBox Grid.Column="2" Style="{StaticResource ToggleSwitch}"
                                                      IsChecked="{Binding AutoStartEnabled}" d:IsLocked="True"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <!-- Card 3: System status -->
                                    <Border Grid.Row="2" Background="#0E1120" BorderBrush="#1A1E30" BorderThickness="1"
                                        CornerRadius="12" Padding="14,10" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <!-- Row: Admin -->
                                            <Grid Margin="0,0,0,7" d:IsLocked="True">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
