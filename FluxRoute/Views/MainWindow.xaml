                                                    <Run Text="Warp: "/><Run Text="{Binding Updates.WarpVersion, Mode=OneWay}" Foreground="#E6EDF3"/>
                                                </TextBlock>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0" d:IsLocked="True">
                                                    <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,6,0" Text="Режим:" d:IsLocked="True"/>
                                                    <ComboBox SelectedIndex="{Binding EngineMode}" Width="155" Height="24" FontFamily="Segoe UI" FontSize="11" d:IsLocked="True"
                                                              ToolTip="Выберите режим работы движков" AutomationProperties.Name="Выбор режима работы движков">
                                                        <ComboBoxItem Content="⚡ Zapret" d:IsLocked="True"/>
                                                        <ComboBoxItem Content="🔒 ByeDPI" d:IsLocked="True"/>
                                                        <ComboBoxItem Content="🌐 Warp" d:IsLocked="True"/>
                                                        <ComboBoxItem Content="⚡🔒 Hybrid" d:IsLocked="True"/>
                                                        <ComboBoxItem Content="🌐⚡ Warp + Zapret" d:IsLocked="True"/>
                                                        <ComboBoxItem Content="🌐🔒 Warp + ByeDPI" d:IsLocked="True"/>
                                                    </ComboBox>
                                                </StackPanel>
                                                <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0" d:IsLocked="True">
                                                    <Run Text="Администратор: "/><Run Text="{Binding AdminText, Mode=OneWay}" Foreground="#E6EDF3"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>

                                        <!-- Quick Actions card -->
                                        <Border Grid.Column="2" Style="{StaticResource Card}" d:IsLocked="True">
                                            <StackPanel d:IsLocked="True">
                                                <TextBlock Text="Быстрые действия" FontFamily="Segoe UI" Foreground="#4FC3F7"
                                                           FontSize="12" FontWeight="Bold" Margin="0,0,0,8" d:IsLocked="True"/>
