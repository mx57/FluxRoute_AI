                                        Padding="10,8" Margin="0,0,0,12" d:IsLocked="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding TgProxyInstalled}" Value="False"/>
                                                            <Condition Binding="{Binding IsTgProxyDownloading}" Value="False"/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock FontFamily="Segoe UI" Foreground="#F0B429" FontSize="12" FontWeight="SemiBold"
                                                   Margin="0,0,0,4" Text="TG WS Proxy не установлен" d:IsLocked="True"/>
                                            <Button Content="Установить TG WS Proxy" Style="{StaticResource ActionBtnAccent}"
                                                HorizontalAlignment="Left" Margin="0,6,0,0"
                                                Command="{Binding DownloadTgProxyCommand}" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Border>
                                    <Border Background="#0D1F0D" BorderBrush="#1A4A1A" BorderThickness="1" CornerRadius="8"
                                        Padding="10,8" Margin="0,0,0,12"
                                        Visibility="{Binding IsTgProxyDownloading, Converter={StaticResource BoolToVis}}" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock FontFamily="Segoe UI" Foreground="#66BB6A" FontSize="12" FontWeight="SemiBold"
                                                   Margin="0,0,0,4" Text="Установка TG WS Proxy..." d:IsLocked="True"/>
                                            <TextBlock Text="{Binding TgProxyDownloadStatus}" FontFamily="Segoe UI"
                                                   Foreground="#A5D6A7" FontSize="11" TextWrapping="Wrap" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Style="{StaticResource SecH}" Text="УПРАВЛЕНИЕ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6" d:IsLocked="True">
                                        <Button Margin="0,0,10,0" Command="{Binding ToggleTgProxyCommand}" IsEnabled="{Binding TgProxyInstalled}" d:IsLocked="True">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ActionBtnGreen}">
                                                    <Setter Property="Content" Value="Запустить прокси"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TgProxyRunning}" Value="True">
                                                            <Setter Property="Content" Value="Остановить прокси"/>
                                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                                            <Setter Property="BorderBrush" Value="#6B1A1A"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Открыть в Telegram" Style="{StaticResource ActionBtnAccent}" Margin="0,0,10,0"
                                            Command="{Binding OpenInTelegramCommand}" IsEnabled="{Binding TgProxyRunning}" d:IsLocked="True"/>
                                        <Button Content="Скопировать ссылку" Style="{StaticResource ActionBtn}"
                                            Command="{Binding CopyTgLinkCommand}" IsEnabled="{Binding TgProxyInstalled}" d:IsLocked="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" d:IsLocked="True">
                                        <TextBlock Style="{StaticResource Lbl}" Text="Версия: " Margin="0,0,4,0" d:IsLocked="True"/>
                                        <TextBlock Style="{StaticResource Val}" Text="{Binding TgProxyVersion}" d:IsLocked="True"/>
                                    </StackPanel>
                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource SecH}" Text="ПОДКЛЮЧЕНИЕ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <Grid Margin="0,0,0,10" d:IsLocked="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="10"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" d:IsLocked="True">
                                            <TextBlock Style="{StaticResource Lbl}" Text="IP-адрес" Margin="0,0,0,4" d:IsLocked="True"/>
                                            <TextBox Text="{Binding TgProxyHost, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" d:IsLocked="True"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" d:IsLocked="True">
                                            <TextBlock Style="{StaticResource Lbl}" Text="Порт" Margin="0,0,0,4" d:IsLocked="True"/>
                                            <TextBox Text="{Binding TgProxyPort, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Grid>
                                    <Grid Margin="0,0,0,4" d:IsLocked="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="36"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding TgProxySecret, UpdateSourceTrigger=PropertyChanged}"
                                             Height="30" VerticalContentAlignment="Center" FontFamily="Consolas" d:IsLocked="True"/>
                                        <Button Grid.Column="2" Height="30" Width="36" Style="{StaticResource ActionBtnAccent}"
                                            Padding="0" Command="{Binding GenerateTgProxySecretCommand}" d:IsLocked="True">
                                            <TextBlock Text="↻" FontSize="14" d:IsLocked="True"/>
                                        </Button>
                                    </Grid>
                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource SecH}" Text="ДАТАЦЕНТРЫ TELEGRAM (DC → IP)" Margin="0,0,0,6" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Формат: номер:IP" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyDcIps, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" MinHeight="56" MaxHeight="100"
                                         VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="11"
                                         VerticalContentAlignment="Top" Padding="6" Margin="0,0,0,12" d:IsLocked="True"/>
                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource SecH}" Text="CLOUDFLARE PROXY" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" d:IsLocked="True">
                                        <CheckBox Content="Включить CF-прокси" IsChecked="{Binding TgProxyCfEnabled}" Margin="0,0,16,0" VerticalAlignment="Center" d:IsLocked="True"/>
                                        <CheckBox Content="Приоритет" IsChecked="{Binding TgProxyCfPriority}" IsEnabled="{Binding TgProxyCfEnabled}" VerticalAlignment="Center" d:IsLocked="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" d:IsLocked="True">
                                        <CheckBox IsChecked="{Binding TgProxyCfDomainEnabled}" IsEnabled="{Binding TgProxyCfEnabled}" VerticalAlignment="Center" Margin="0,0,8,0" d:IsLocked="True"/>
                                        <TextBox Text="{Binding TgProxyCfDomain, UpdateSourceTrigger=PropertyChanged}"
                                             Height="30" VerticalContentAlignment="Center" FontSize="12" Width="260"
                                             IsEnabled="{Binding TgProxyCfDomainEnabled}" d:IsLocked="True"/>
                                    </StackPanel>
                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource SecH}" Text="ЛОГИ И ПРОИЗВОДИТЕЛЬНОСТЬ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <CheckBox Content="Подробное логирование (verbose)" IsChecked="{Binding TgProxyVerbose}" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Буфер, КБ" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyBufKb, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Пул WebSocket-сессий" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyPoolSize, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Макс. размер лога, МБ" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyLogMaxMb, UpdateSourceTrigger=PropertyChanged}" Height="30" VerticalContentAlignment="Center" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <CheckBox Content="Предпочитать IPv4" IsChecked="{Binding TgProxyPreferIPv4}" Margin="0,0,0,12" d:IsLocked="True"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- ╔══════════ TAB 2: ОРКЕСТРАТОР ══════════╗ -->
                        <Border d:IsLocked="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="2">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" d:IsLocked="True">
                                <StackPanel Margin="16,12" d:IsLocked="True">
                                    <TextBlock Style="{StaticResource SecH}" Text="УПРАВЛЕНИЕ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10" d:IsLocked="True">
                                        <Button Margin="0,0,10,0" Command="{Binding ToggleOrchestratorCommand}" d:IsLocked="True">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource ActionBtn}">
                                                    <Setter Property="Content" Value="Запустить оркестратор"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding OrchestratorRunning}" Value="True">
                                                            <Setter Property="Content" Value="Остановить оркестратор"/>
                                                            <Setter Property="BorderBrush" Value="#6B1A1A"/>
                                                            <Setter Property="Foreground" Value="#E74C3C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="Проверить сейчас" Style="{StaticResource ActionBtn}" Command="{Binding CheckNowCommand}" d:IsLocked="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4" d:IsLocked="True">
                                        <TextBlock Style="{StaticResource Lbl}" Text="Интервал (мин): " Margin="0,0,8,0" d:IsLocked="True"/>
                                        <TextBox Text="{Binding OrchestratorInterval, UpdateSourceTrigger=PropertyChanged}"
                                             Width="50" Height="28" VerticalContentAlignment="Center" d:IsLocked="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0" d:IsLocked="True">
                                        <TextBlock Style="{StaticResource Lbl}" Text="Следующая проверка: " Margin="0,0,4,0" d:IsLocked="True"/>
                                        <TextBlock Style="{StaticResource Val}" Text="{Binding OrchestratorNextCheck}" d:IsLocked="True"/>
                                    </StackPanel>
                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource SecH}" Text="САЙТЫ ДЛЯ ПРОВЕРКИ" d:IsLocked="True"/>
                                    <WrapPanel Margin="0,0,0,8" d:IsLocked="True">
                                        <CheckBox Content="YouTube"   IsChecked="{Binding SiteYouTube}"   Margin="0,4,16,4" d:IsLocked="True"/>
                                        <CheckBox Content="Discord"   IsChecked="{Binding SiteDiscord}"   Margin="0,4,16,4" d:IsLocked="True"/>
                                        <CheckBox Content="Google"    IsChecked="{Binding SiteGoogle}"    Margin="0,4,16,4" d:IsLocked="True"/>
                                        <CheckBox Content="Twitch"    IsChecked="{Binding SiteTwitch}"    Margin="0,4,16,4" d:IsLocked="True"/>
                                        <CheckBox Content="Instagram" IsChecked="{Binding SiteInstagram}" Margin="0,4,16,4" d:IsLocked="True"/>
                                        <CheckBox Content="Telegram"  IsChecked="{Binding SiteTelegram}"  Margin="0,4,16,4" d:IsLocked="True"/>
                                    </WrapPanel>

                                    <Border Margin="0,0,0,8" d:IsLocked="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AiEnabled}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock Style="{StaticResource SecH}" Text="СТРАТЕГИИ ИИ" d:IsLocked="True"/>
                                            <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E" TextWrapping="Wrap" Margin="0,0,0,8"
                                                       Text="Снимите галочку, чтобы исключить стратегию из подбора ИИ и эволюции." d:IsLocked="True"/>
                                            <ItemsControl ItemsSource="{Binding AiStrategyRows}" d:IsLocked="True">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#111520" Padding="10,6" Margin="0,2">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                                                                    <CheckBox IsChecked="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                                                    <Button Content="🗑" Style="{StaticResource RedBtn}" Width="28" Height="28" Padding="0" FontSize="12"
                                                                            Visibility="{Binding CanDelete, Converter={StaticResource BoolToVis}}"
                                                                            Command="{Binding DataContext.DeleteAiStrategyCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                            CommandParameter="{Binding}"
                                                                            ToolTip="Удалить эволюционированную стратегию"/>
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding DisplayName}" FontFamily="Segoe UI" Foreground="#C8D4EC" FontSize="13"/>
                                                                    <TextBlock Text="{Binding OriginTag}" FontFamily="Segoe UI" Foreground="#8B949E" FontSize="11"/>
                                                                </StackPanel>
                                                                <TextBlock Grid.Column="2" Text="{Binding WilsonText}" ToolTip="{Binding WilsonToolTip}" FontFamily="Segoe UI" Foreground="#4FC3F7" FontSize="12" VerticalAlignment="Center" Margin="8,0,8,0"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding VerificationText}" ToolTip="{Binding VerificationToolTip}" FontFamily="Segoe UI" Foreground="#79C0FF" FontSize="12" VerticalAlignment="Center"/>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource SecH}" Text="РЕЙТИНГ ПРОФИЛЕЙ" d:IsLocked="True"/>
                                    <Button HorizontalAlignment="Left" Margin="0,0,0,10" Command="{Binding ScanProfilesCommand}" d:IsLocked="True">
