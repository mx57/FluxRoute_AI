                                               FontWeight="Bold" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBlock Text="Параметры генерации командной строки ciadpi.exe. Применяются при запуске ByeDPI-стратегий ИИ."
                                               Foreground="#8B949E" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14" d:IsLocked="True"/>

                                    <!-- === Сеть === -->
                                    <Border Style="{StaticResource Card}" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock Text="Сеть" Style="{StaticResource SecH}" d:IsLocked="True"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" d:IsLocked="True">
                                                <TextBlock Text="SOCKS5 порт:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiSocksPort, UpdateSourceTrigger=PropertyChanged}" Width="80" d:IsLocked="True"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Split (позиция):" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiSplitPos, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="Split packet at position, e.g. 2,5,-2" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Disorder (позиция):" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiDisorderPos, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="Disorder packet at position, e.g. 1" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Timeout (мс):" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiTimeout, UpdateSourceTrigger=PropertyChanged}" Width="80" d:IsLocked="True" ToolTip="Connection timeout in milliseconds" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Rectangle Style="{StaticResource Sep}" Margin="0,12" d:IsLocked="True"/>

                                    <!-- === Fake / TLS === -->
                                    <Border Style="{StaticResource Card}" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock Text="Fake / TLS" Style="{StaticResource SecH}" d:IsLocked="True"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" d:IsLocked="True">
                                                <TextBlock Text="Fake (позиция):" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiFakePos, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="Fake packet at position" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Fake TTL:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiFakeTtl, UpdateSourceTrigger=PropertyChanged}" Width="80" d:IsLocked="True" ToolTip="TTL for fake packets" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Fake TLS mod:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiFakeTlsMod, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="Fake TLS modification, e.g. all, hello" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Fake SNI:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiFakeSni, UpdateSourceTrigger=PropertyChanged}" Width="160" d:IsLocked="True" ToolTip="Fake SNI for TLS" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Fake data:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiFakeData, UpdateSourceTrigger=PropertyChanged}" Width="160" d:IsLocked="True" ToolTip="Fake payload data" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="OOB (позиция):" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiOobPos, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="Out-of-band data at position" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="TLSrec (позиция):" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiTlsrecPos, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="TLS record split at position" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="TLS minor ver:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiTlsminor, UpdateSourceTrigger=PropertyChanged}" Width="80" d:IsLocked="True" ToolTip="TLS minor version override" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Rectangle Style="{StaticResource Sep}" Margin="0,12" d:IsLocked="True"/>

                                    <!-- === Авто / Хосты === -->
                                    <Border Style="{StaticResource Card}" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock Text="Авто / Хосты" Style="{StaticResource SecH}" d:IsLocked="True"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0" d:IsLocked="True">
                                                <TextBlock Text="Auto TTL:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <CheckBox IsChecked="{Binding ByeDpiAutoTtl}" d:IsLocked="True"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Auto mode:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiAutoMode, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="Auto mode string: torst, tcnt, icmp, etc." />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Hosts:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiHosts, UpdateSourceTrigger=PropertyChanged}" Width="200" d:IsLocked="True" ToolTip="Comma-separated host list" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Hostlist file:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiHostlist, UpdateSourceTrigger=PropertyChanged}" Width="200" d:IsLocked="True" ToolTip="Path to hostlist file" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="Mod HTTP:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <TextBox Text="{Binding ByeDpiModHttp, UpdateSourceTrigger=PropertyChanged}" Width="120" d:IsLocked="True" ToolTip="HTTP modification mode" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" d:IsLocked="True">
                                                <TextBlock Text="MD5 Signature:" Width="120" VerticalAlignment="Center" d:IsLocked="True"/>
                                                <CheckBox IsChecked="{Binding ByeDpiMd5sig}" d:IsLocked="True"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <Rectangle Style="{StaticResource Sep}" Margin="0,12" d:IsLocked="True"/>

                                    <!-- === Info === -->
                                    <Border Style="{StaticResource Card}" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock Text="Информация" Style="{StaticResource SecH}" d:IsLocked="True"/>
                                            <TextBlock Text="ByeDPI используется для обхода DPI через SOCKS5 прокси. При выборе режима ByeDPI или Hybrid ИИ будет генерировать командные строки ciadpi.exe вместо winws.exe."
                                                       Foreground="#8B949E" FontSize="11" TextWrapping="Wrap" d:IsLocked="True"/>
                                            <TextBlock Text="Параметры above используются ИИ как дефолтные значения для эволюции ByeDPI-стратегий. Значения с префиксом «-» в геноме перезаписывают эти дефолты."
                                                       Foreground="#8B949E" FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>


                        <!-- ╔══════════════════════════════════════╗ -->
                        <!-- ║          TAB 10: WARP               ║ -->
                        <!-- ╚══════════════════════════════════════╝ -->
                        <Border d:IsLocked="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="10">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0" To="1" Duration="0:0:0.3">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12" d:IsLocked="True">
                                <StackPanel d:IsLocked="True">
                                    <TextBlock Text="Cloudflare Warp" Foreground="#4FC3F7" FontSize="14"
                                               FontWeight="Bold" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBlock Text="Генерация конфигурации для Cloudflare Warp (WireGuard)."
                                               Foreground="#8B949E" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,14" d:IsLocked="True"/>

                                    <Border Style="{StaticResource Card}" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <Button Content="Генерировать конфиг" Style="{StaticResource AccentBtn}"
                                                    Command="{Binding GenerateWarpConfigCommand}" d:IsLocked="True"/>

                                            <TextBlock Text="Результат:" Style="{StaticResource SecH}" d:IsLocked="True"/>
                                            <TextBox Text="{Binding WarpConfigResult}" Height="200"
                                                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                                     IsReadOnly="True" FontFamily="Consolas" FontSize="11" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- ╔══════════════════════════════════════╗ -->
                        <!-- ║     TAB 11: КОНСТРУКТОР             ║ -->
                        <!-- ╚══════════════════════════════════════╝ -->
                        <Border d:IsLocked="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="11">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0" To="1" Duration="0:0:0.3">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid d:IsLocked="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left panel: chain list + node palette -->
                                <Border Grid.Column="0" Background="#0D1117" BorderBrush="#30363D"
                                        BorderThickness="0,0,1,0" Padding="12,12,8,12" d:IsLocked="True">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock Text="КОНСТРУКТОР" FontFamily="Segoe UI" FontSize="14"
                                                       FontWeight="Bold" Foreground="#4FC3F7" Margin="0,0,0,12" d:IsLocked="True"/>

                                            <!-- Chain list -->
                                            <TextBlock Text="Цепочки" FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="#8B949E" Margin="0,0,0,6" d:IsLocked="True"/>
                                            <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                                                    CornerRadius="6" Padding="4" Margin="0,0,0,12" d:IsLocked="True">
                                                <StackPanel d:IsLocked="True">
                                                    <ItemsControl ItemsSource="{Binding ChainBuilder.ChainList}" d:IsLocked="True">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Background="#1C2128" Padding="8,6" Margin="0,2"
                                                                        CornerRadius="4" Cursor="Hand"
                                                                        MouseLeftButtonDown="ChainListItem_MouseDown"
                                                                        d:IsLocked="True">
                                                                    <StackPanel Orientation="Horizontal" d:IsLocked="True">
                                                                        <TextBlock Text="{Binding Name}" FontFamily="Segoe UI"
                                                                                   Foreground="#E6EDF3" FontSize="12"
                                                                                   VerticalAlignment="Center" d:IsLocked="True"/>
                                                                    </StackPanel>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </Border>
                                            <Button Content="+ Новая цепочка" Style="{StaticResource AccentBtn}"
                                                    Margin="0,0,0,16" Command="{Binding ChainBuilder.NewChainCommand}" d:IsLocked="True"/>

                                            <!-- Node palette -->
                                            <TextBlock Text="Узлы" FontFamily="Segoe UI" FontSize="12"
                                                       Foreground="#8B949E" Margin="0,0,0,6" d:IsLocked="True"/>
                                            <Border Background="#161B22" BorderBrush="#30363D" BorderThickness="1"
                                                    CornerRadius="6" Padding="4" d:IsLocked="True">
                                                <WrapPanel d:IsLocked="True">
                                                    <Button Content="💻 Программа" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="Program" d:IsLocked="True"/>
                                                    <Button Content="🔍 Проверка" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="Probe" d:IsLocked="True"/>
                                                    <Button Content="🛡 Zapret" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="Zapret" d:IsLocked="True"/>
                                                    <Button Content="🛡 ByeDPI" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="ByeDpi" d:IsLocked="True"/>
                                                    <Button Content="⚡ WARP" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="Warp" d:IsLocked="True"/>
                                                    <Button Content="⏱ Задержка" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="Delay" d:IsLocked="True"/>
                                                    <Button Content="📝 Лог" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="Log" d:IsLocked="True"/>
                                                    <Button Content="🌐 Интернет" Style="{StaticResource TermBtn}"
                                                            Margin="0,0,4,4" FontSize="11" Padding="8,4"
                                                            Command="{Binding ChainBuilder.AddNodeCommand}" CommandParameter="Internet" d:IsLocked="True"/>
                                                </WrapPanel>
                                            </Border>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>

                                <!-- Right panel: canvas -->
                                <Border Grid.Column="1" Background="#161B22" d:IsLocked="True">
                                    <Grid d:IsLocked="True">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <!-- Stats bar -->
                                        <Border Grid.Row="0" Background="#0D1117" BorderBrush="#30363D" BorderThickness="0,0,0,1"
                                                Padding="12,8" d:IsLocked="True">
                                            <StackPanel Orientation="Horizontal" d:IsLocked="True">
                                                <Border Background="#1C2128" CornerRadius="6" Padding="10,4" Margin="0,0,8,0" d:IsLocked="True">
                                                    <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E" d:IsLocked="True">
                                                        <Run Text="Узлы: " Foreground="#8B949E"/><Run Text="{Binding ChainBuilder.NodeCount, Mode=OneWay}" Foreground="#E6EDF3"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#1C2128" CornerRadius="6" Padding="10,4" Margin="0,0,8,0" d:IsLocked="True">
                                                    <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E" d:IsLocked="True">
                                                        <Run Text="Связи: " Foreground="#8B949E"/><Run Text="{Binding ChainBuilder.ConnectionCount, Mode=OneWay}" Foreground="#E6EDF3"/>
                                                    </TextBlock>
                                                </Border>
                                                <Border Background="#1C2128" CornerRadius="6" Padding="10,4" Margin="0,0,8,0" d:IsLocked="True">
                                                    <TextBlock Text="{Binding ChainBuilder.ActiveChainName}" FontFamily="Segoe UI"
                                                               FontSize="11" Foreground="#4FC3F7" d:IsLocked="True"/>
                                                </Border>
                                                <Button Content="✕ Удалить узел" Style="{StaticResource TermBtn}"
                                                        FontSize="11" Padding="8,4" Margin="0,0,4,0"
                                                        Command="{Binding ChainBuilder.DeleteSelectedNodeCommand}"
                                                        CommandParameter="{Binding ChainBuilder.SelectedNode}"
                                                        Visibility="{Binding ChainBuilder.SelectedNode, Converter={StaticResource NullToVis}}" d:IsLocked="True"/>
                                                <Button Content="↺ Сброс вида" Style="{StaticResource TermBtn}"
                                                        FontSize="11" Padding="8,4"
                                                        Click="ResetChainView_Click" d:IsLocked="True"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Node canvas -->
                                        <controls:NodeCanvas Grid.Row="1" x:Name="ChainCanvas" ClipToBounds="True" Background="#161B22" d:IsLocked="True"/>

                                        <!-- Empty state -->
                                        <TextBlock Grid.Row="1" Text="Нажмите «+ Новая цепочка» для начала"
                                                   FontFamily="Segoe UI" FontSize="14" Foreground="#484F58"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IsHitTestVisible="False" d:IsLocked="True">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding ChainBuilder.NodeCount}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ╔══════════════════════════════════════╗ -->
                        <!-- ║          TAB 8: ЛОГИ                ║ -->
                        <!-- ╚══════════════════════════════════════╝ -->
                        <Border d:IsLocked="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="8">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Setter Property="Opacity" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid Margin="16,12" d:IsLocked="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="#0D1117" BorderBrush="#30363D"
                                        BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,14"
                                        Panel.ZIndex="2" d:IsLocked="True">
                                    <StackPanel d:IsLocked="True">
                                        <TextBlock Text="Логи" Foreground="#4FC3F7" FontSize="14"
                                                   FontWeight="Bold" Margin="0,0,0,4" d:IsLocked="True"/>
                                        <TextBlock Text="Здесь собраны события приложения, оркестратора, проверки профилей, winws.exe, TG WS Proxy, обновлений и сервиса."
                                                   Foreground="#8B949E" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10" d:IsLocked="True"/>

                                        <WrapPanel VerticalAlignment="Center" d:IsLocked="True">
                                            <TextBlock Text="Тип:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,6,0" d:IsLocked="True"/>
                                            <ComboBox Width="210" Height="28" Margin="0,0,10,8"
                                                      ItemsSource="{Binding LogCategoryFilters}"
                                                      SelectedItem="{Binding SelectedLogCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" d:IsLocked="True"
                                                      ToolTip="Фильтровать логи по категории" AutomationProperties.Name="Выбор категории логов"/>

                                            <TextBlock Text="Поиск:" Foreground="#8B949E" VerticalAlignment="Center" Margin="0,0,6,0" d:IsLocked="True"/>
                                            <TextBox Width="220" Height="28" Margin="0,0,10,8" VerticalContentAlignment="Center"
                                                     Text="{Binding LogSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" d:IsLocked="True"
                                                     ToolTip="Введите текст для поиска в логах" AutomationProperties.Name="Поиск в логах"/>

                                            <CheckBox Content="Только ошибки" Foreground="#C9D1D9" Margin="0,4,12,8"
                                                      VerticalAlignment="Center" IsChecked="{Binding LogsErrorsOnly, Mode=TwoWay}" d:IsLocked="True"/>
                                            <CheckBox Content="Автопрокрутка" Foreground="#C9D1D9" Margin="0,4,12,8"
                                                      VerticalAlignment="Center" IsChecked="{Binding LogsAutoScroll, Mode=TwoWay}" d:IsLocked="True"/>

                                            <Button Content="Очистить" Style="{StaticResource TermBtn}" Height="28" Padding="10,0" Margin="0,0,8,8"
                                                    Command="{Binding ClearUnifiedLogsCommand}"
                                                    ToolTip="Очистить все логи"
                                                    AutomationProperties.Name="Очистить все логи" d:IsLocked="True"/>
                                            <Button Content="Скопировать" Style="{StaticResource TermBtn}" Height="28" Padding="10,0" Margin="0,0,8,8"
                                                    Command="{Binding CopyUnifiedLogsCommand}"
                                                    ToolTip="Скопировать логи в буфер обмена"
                                                    AutomationProperties.Name="Скопировать логи в буфер обмена" d:IsLocked="True"/>
                                            <Button Content="Сохранить" Style="{StaticResource TermBtn}" Height="28" Padding="10,0" Margin="0,0,8,8"
                                                    Command="{Binding SaveUnifiedLogsCommand}"
                                                    ToolTip="Сохранить логи в файл"
                                                    AutomationProperties.Name="Сохранить логи в файл" d:IsLocked="True"/>
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Separate host border prevents the first log line from being visually clipped by the filters card. -->
                                <Border Grid.Row="1" Background="#010409" BorderBrush="#30363D" BorderThickness="1"
                                        Padding="0" Margin="0,0,0,0" Panel.ZIndex="1" d:IsLocked="True">
                                    <TextBox x:Name="UnifiedLogsTextBox"
                                             Background="Transparent" Foreground="#C9D1D9" BorderThickness="0"
                                             FontFamily="Consolas" FontSize="12" Padding="10,8" IsReadOnly="True" IsUndoEnabled="False"
                                             AcceptsReturn="True" AcceptsTab="False" TextWrapping="Wrap"
                                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                             Text="{Binding UnifiedLogsText, Mode=OneWay}" d:IsLocked="True"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ╔══════════════════════════════════════╗ -->
                        <!-- ║       TAB 7: О ПРОГРАММЕ            ║ -->
                        <!-- ╚══════════════════════════════════════╝ -->
                        <Border d:IsLocked="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Setter Property="Opacity" Value="0"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="7">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="0" To="1" Duration="0:0:0.3">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" d:IsLocked="True">
                                <StackPanel Margin="16,12" d:IsLocked="True">

                                    <TextBlock Style="{StaticResource SecH}" Text="ДЛЯ ЧЕГО СОЗДАН ПРОЕКТ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" TextWrapping="Wrap" FontSize="12"
                                               Text="FluxRoute создан как удобный desktop-интерфейс для управления сетевыми профилями и сценариями обхода ограничений. Главная цель — упростить запуск и переключение стратегий без ручного редактирования bat-файлов." d:IsLocked="True"/>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <TextBlock Style="{StaticResource SecH}" Text="КАК РАБОТАЕТ" d:IsLocked="True"/>
                                    <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" TextWrapping="Wrap" FontSize="12"
                                               Text="Приложение загружает профили из каталога engine, запускает выбранный сценарий, отслеживает статус процесса и диагностику. Оркестратор анализирует доступность целей и переключает профиль на более стабильный." d:IsLocked="True"/>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <TextBlock Style="{StaticResource SecH}" Text="ОСНОВА ENGINE" d:IsLocked="True"/>
                                    <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" TextWrapping="Wrap" FontSize="12"
                                               Text="FluxRoute использует экосистему проектов:" d:IsLocked="True"/>
                                    <StackPanel Margin="8,8,0,0" d:IsLocked="True">
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
                                            <Run Text="• "/><Hyperlink NavigateUri="https://github.com/basil00/WinDivert" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/basil00/WinDivert">WinDivert</Hyperlink>
                                            <Run Text=" — низкоуровневая основа"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
                                            <Run Text="• "/><Hyperlink NavigateUri="https://github.com/bol-van/zapret" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/bol-van/zapret">bol-van/zapret</Hyperlink>
                                            <Run Text=" — оригинальный проект"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
                                            <Run Text="• "/><Hyperlink NavigateUri="https://github.com/bol-van/zapret-win-bundle" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/bol-van/zapret-win-bundle">zapret-win-bundle</Hyperlink>
                                            <Run Text=" — Windows-бандл"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
                                            <Run Text="• "/><Hyperlink NavigateUri="https://github.com/Flowseal/zapret-discord-youtube" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/Flowseal/zapret-discord-youtube">Flowseal/zapret-discord-youtube</Hyperlink>
                                            <Run Text=" — основа engine"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <TextBlock Style="{StaticResource SecH}" Text="ВДОХНОВЕНИЕ" d:IsLocked="True"/>
                                    <StackPanel Margin="8,0,0,0" d:IsLocked="True">
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
                                            <Run Text="• "/><Hyperlink NavigateUri="https://github.com/medvedeff-true/Zapret-GUI" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/medvedeff-true/Zapret-GUI">medvedeff-true/Zapret-GUI</Hyperlink>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
                                            <Run Text="• "/><Hyperlink NavigateUri="https://github.com/Virenbar/ZapretControl" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/Virenbar/ZapretControl">Virenbar/ZapretControl</Hyperlink>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
											<Run Text="• "/><Hyperlink NavigateUri="https://github.com/youtubediscord/zapret" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/youtubediscord/zapret">youtubediscord/zapret</Hyperlink>
                                        </TextBlock>
                                    </StackPanel>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <TextBlock Style="{StaticResource SecH}" Text="ПОЛЕЗНЫЕ ССЫЛКИ" d:IsLocked="True"/>
                                    <StackPanel Margin="8,0,0,0" d:IsLocked="True">
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
											<Run Text="• "/><Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/klondike0x/FluxRoute">FluxRoute на GitHub</Hyperlink>
											<Run Text=" — репозиторий проекта"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
											<Run Text="• "/><Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute/releases" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/klondike0x/FluxRoute/releases">Релизы</Hyperlink>
											<Run Text=" — скачать последнюю версию"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
											<Run Text="• "/><Hyperlink NavigateUri="https://github.com/klondike0x/FluxRoute/issues" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/klondike0x/FluxRoute/issues">Issues</Hyperlink>
											<Run Text=" — баг-репорты и предложения"/>
                                        </TextBlock>
                                        <TextBlock FontFamily="Segoe UI" Foreground="#C9D1D9" FontSize="12" Margin="0,3" d:IsLocked="True">
											<Run Text="• "/><Hyperlink NavigateUri="https://github.com/klondike0x" RequestNavigate="Hyperlink_RequestNavigate" Foreground="#4FC3F7" ToolTip="Перейти: https://github.com/klondike0x">klondike0x</Hyperlink>
											<Run Text=" — страница автора на GitHub"/>
                                        </TextBlock>
                                    </StackPanel>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <!-- ╔══════════════════════════════════════╗ -->
                        <!-- ║       TAB 6: TG ПРОКСИ              ║ -->
                        <!-- ╚══════════════════════════════════════╝ -->
                        <Border d:IsLocked="True">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Setter Property="Opacity" Value="0" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedTabIndex}" Value="1">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
																					 From="0" To="1" Duration="0:0:0.3">
                                                            <DoubleAnimation.EasingFunction>
                                                                <CubicEase EasingMode="EaseOut"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" d:IsLocked="True">
                                <StackPanel Margin="16,12" d:IsLocked="True">

                                    <!-- Баннер: не установлен -->
                                    <Border Background="#1C1500" BorderBrush="#5A4800" BorderThickness="1"
														Padding="10,8" Margin="0,0,0,12" d:IsLocked="True">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition
                                                                Binding="{Binding TgProxyInstalled}"
                                                                Value="False" />
                                                            <Condition
                                                                Binding="{Binding IsTgProxyDownloading}"
                                                                Value="False" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility"
                                                            Value="Visible" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock FontFamily="Segoe UI" Foreground="#FFD700" FontSize="12"
							   FontWeight="SemiBold" Margin="0,0,0,4"
							   Text="⚠️ TG WS Proxy не установлен" d:IsLocked="True"/>
                                            <Button Content="⬇️ Установить TG WS Proxy" Style="{StaticResource AccentBtn}"
							HorizontalAlignment="Left" Margin="0,6,0,0" FontSize="12" Padding="10,5"
							Command="{Binding DownloadTgProxyCommand}" d:IsLocked="True"
                                                            ToolTip="Скачать и установить компоненты TG WS Proxy"
                                                            AutomationProperties.Name="Установить TG WS Proxy"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- Прогресс установки -->
                                    <Border Background="#0D1F0D" BorderBrush="#1A4A1A" BorderThickness="1"
					Padding="10,8" Margin="0,0,0,12"
					Visibility="{Binding IsTgProxyDownloading, Converter={StaticResource BoolToVis}}" d:IsLocked="True">
                                        <StackPanel d:IsLocked="True">
                                            <TextBlock FontFamily="Segoe UI" Foreground="#66BB6A" FontSize="12"
							   FontWeight="SemiBold" Margin="0,0,0,4"
							   Text="⬇️ Установка TG WS Proxy..." d:IsLocked="True"/>
                                            <TextBlock Text="{Binding TgProxyDownloadStatus}" FontFamily="Segoe UI"
							   Foreground="#A5D6A7" FontSize="11" TextWrapping="Wrap" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- УПРАВЛЕНИЕ -->
                                    <TextBlock Style="{StaticResource SecH}" Text="УПРАВЛЕНИЕ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6" FlowDirection="LeftToRight" d:IsLocked="True">
                                        <Button Margin="0,0,10,0" Command="{Binding ToggleTgProxyCommand}"
                                                IsEnabled="{Binding TgProxyInstalled}" d:IsLocked="True"
                                                ToolTip="Запустить или остановить службу TG WS Proxy"
                                                AutomationProperties.Name="Запуск или остановка прокси">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource GreenBtn}">
                                                    <Setter Property="Content" Value="▶ Запустить прокси"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding TgProxyRunning}" Value="True">
                                                            <Setter Property="Content" Value="⏹ Остановить прокси"/>
                                                            <Setter Property="Foreground" Value="#F85149"/>
                                                            <Setter Property="BorderBrush" Value="#DA3633"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                        <Button Content="📲 Открыть в Telegram" Style="{StaticResource AccentBtn}" Margin="10,0,0,0"
                                                Command="{Binding OpenInTelegramCommand}"
                                                IsEnabled="{Binding TgProxyRunning}" d:IsLocked="True"
                                                ToolTip="Открыть сгенерированную ссылку в приложении Telegram"
                                                AutomationProperties.Name="Открыть прокси в Telegram"/>
                                        <Button Content="📋 Скопировать ссылку" Style="{StaticResource TermBtn}" Margin="10,0,0,0"
                                                Command="{Binding CopyTgLinkCommand}"
                                                IsEnabled="{Binding TgProxyInstalled}" d:IsLocked="True"
                                                ToolTip="Копировать ссылку подключения в буфер обмена"
                                                AutomationProperties.Name="Скопировать ссылку прокси"/>
                                    </StackPanel>

                                    <!-- Статус версии -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" d:IsLocked="True">
                                        <TextBlock Style="{StaticResource Lbl}" Text="Версия: " Margin="0,0,4,0" d:IsLocked="True"/>
                                        <TextBlock Style="{StaticResource Val}" Text="{Binding TgProxyVersion}" d:IsLocked="True"/>
                                    </StackPanel>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <!-- ПОДКЛЮЧЕНИЕ -->
                                    <TextBlock Style="{StaticResource SecH}" Text="ПОДКЛЮЧЕНИЕ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <Grid Margin="0,0,0,10" d:IsLocked="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" d:IsLocked="True">
                                            <TextBlock Style="{StaticResource Lbl}" Text="IP-адрес прослушивания" Margin="0,0,0,4" d:IsLocked="True"/>
                                            <TextBox Text="{Binding TgProxyHost, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center" d:IsLocked="True"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" d:IsLocked="True">
                                            <TextBlock Style="{StaticResource Lbl}" Text="Порт" Margin="0,0,0,4" d:IsLocked="True"/>
                                            <TextBox Text="{Binding TgProxyPort, UpdateSourceTrigger=PropertyChanged}" Height="28" VerticalContentAlignment="Center" d:IsLocked="True"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- SECRET -->
                                    <Grid Margin="0,0,0,4" d:IsLocked="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="6" />
                                            <ColumnDefinition Width="36" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" Text="{Binding TgProxySecret, UpdateSourceTrigger=PropertyChanged}"
															 Height="28" VerticalContentAlignment="Center" FontFamily="Consolas" d:IsLocked="True"/>
                                        <Button Grid.Column="2" Height="28" Width="36" Style="{StaticResource AccentBtn}"
															Padding="0" Command="{Binding GenerateTgProxySecretCommand}"
                                                            ToolTip="Генерировать Secret" AutomationProperties.Name="Генерировать секрет" d:IsLocked="True">
                                            <TextBlock Text="🔄" FontSize="12" d:IsLocked="True"/>
                                        </Button>
                                    </Grid>
                                    <!-- ДОМЕН FAKE-TLS -->

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <!-- ДАТАЦЕНТРЫ TELEGRAM -->
                                    <TextBlock Style="{StaticResource SecH}" Text="ДАТАЦЕНТРЫ TELEGRAM (DC → IP)" Margin="0,0,0,6" d:IsLocked="True"/>
                                    <TextBlock FontFamily="Segoe UI" Foreground="#484F58" FontSize="11"
											   Margin="0,0,0,4" Text="По одному правилу на строку, формат: номер:IP" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyDcIps, UpdateSourceTrigger=PropertyChanged}"
											 AcceptsReturn="True" MinHeight="56" MaxHeight="100"
											 VerticalScrollBarVisibility="Auto"
											 FontFamily="Consolas" FontSize="11"
											 VerticalContentAlignment="Top" Padding="4" Margin="0,0,0,12" d:IsLocked="True"/>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <!-- CLOUDFLARE PROXY -->
                                    <TextBlock Style="{StaticResource SecH}" Text="CLOUDFLARE PROXY" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8" d:IsLocked="True">
                                        <CheckBox Content="Включить CF-прокси" IsChecked="{Binding TgProxyCfEnabled}" Margin="0,0,16,0" VerticalAlignment="Center" d:IsLocked="True"/>
                                        <CheckBox Content="Приоритет" IsChecked="{Binding TgProxyCfPriority}"
												  IsEnabled="{Binding TgProxyCfEnabled}" VerticalAlignment="Center" d:IsLocked="True"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12" d:IsLocked="True">
                                        <CheckBox IsChecked="{Binding TgProxyCfDomainEnabled}"
												  IsEnabled="{Binding TgProxyCfEnabled}"
												  VerticalAlignment="Center" Margin="0,0,8,0" d:IsLocked="True"/>
                                        <TextBox Text="{Binding TgProxyCfDomain, UpdateSourceTrigger=PropertyChanged}"
												 Height="28" VerticalContentAlignment="Center" FontSize="12"
												 Width="260"
												 IsEnabled="{Binding TgProxyCfDomainEnabled}" d:IsLocked="True"/>
                                    </StackPanel>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <!-- НАСТРОЙКИ -->
                                    <TextBlock Style="{StaticResource SecH}" Text="ЛОГИ И ПРОИЗВОДИТЕЛЬНОСТЬ" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <CheckBox Content="Подробное логирование (verbose)" IsChecked="{Binding TgProxyVerbose}" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Буфер, КБ (по умолчанию 256)" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyBufKb, UpdateSourceTrigger=PropertyChanged}"
											 Height="28" VerticalContentAlignment="Center" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Пул WebSocket-сессий (по умолчанию 4)" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyPoolSize, UpdateSourceTrigger=PropertyChanged}"
											 Height="28" VerticalContentAlignment="Center" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <TextBlock Style="{StaticResource Lbl}" Text="Макс. размер лога, МБ (по умолчанию 5)" Margin="0,0,0,4" d:IsLocked="True"/>
                                    <TextBox Text="{Binding TgProxyLogMaxMb, UpdateSourceTrigger=PropertyChanged}"
											 Height="28" VerticalContentAlignment="Center" Margin="0,0,0,8" d:IsLocked="True"/>
                                    <CheckBox Content="Предпочитать IPv4" IsChecked="{Binding TgProxyPreferIPv4}" Margin="0,0,0,12" d:IsLocked="True"/>

                                    <Rectangle Style="{StaticResource Sep}" d:IsLocked="True"/>

                                    <!-- ЛОГ -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6" Visibility="Collapsed" d:IsLocked="True">
                                        <TextBlock Style="{StaticResource SecH}" Text="ЛОГ" Margin="0,14,12,8" d:IsLocked="True"/>
                                        <Button Content="🗑 Очистить" Style="{StaticResource TermBtn}"
														Padding="8,4" FontSize="11" VerticalAlignment="Center"
														Command="{Binding ClearTgProxyLogsCommand}" d:IsLocked="True"
                                                        ToolTip="Очистить лог событий TG WS Proxy"
                                                        AutomationProperties.Name="Очистить лог прокси"/>
                                    </StackPanel>
                                    <Border Style="{StaticResource LogArea}" MaxHeight="200" Visibility="Collapsed" d:IsLocked="True">
                                        <ItemsControl ItemsSource="{Binding TgProxyLogs}" d:IsLocked="True">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding}" Foreground="{Binding Converter={StaticResource LogColorConv}}"
																	   FontFamily="Segoe UI" FontSize="11" Margin="0,2"/>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                    </Grid>
                </Grid>
            </Grid>

            <!-- ═══════════ STATUS BAR ═══════════ -->
            <Border Grid.Row="2" Background="#010409" BorderBrush="#21262D" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,4,4" Grid.ColumnSpan="2" d:IsLocked="True">
                <Grid Margin="14,0" d:IsLocked="True">
                    <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                               VerticalAlignment="Center" HorizontalAlignment="Left" d:IsLocked="True">
                        <Run Text="v"/><Run Text="{Binding AppVersion, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontFamily="Segoe UI" FontSize="11" Foreground="#8B949E"
                               VerticalAlignment="Center" HorizontalAlignment="Right" d:IsLocked="True">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Ready"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                        <Setter Property="Text" Value="● Active"/>
                                        <Setter Property="Foreground" Value="#3FB950"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>