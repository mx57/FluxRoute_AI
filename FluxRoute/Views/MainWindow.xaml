                                                </TextBlock>
                                                <TextBlock FontFamily="Segoe UI" FontSize="12" Foreground="#8B949E" Margin="0,2,0,0" d:IsLocked="True">
                                                    <Run Text="ByeDPI: "/><Run Text="{Binding Updates.ByeDpiVersion, Mode=OneWay}" Foreground="#E6EDF3"/>
                                                </TextBlock>
