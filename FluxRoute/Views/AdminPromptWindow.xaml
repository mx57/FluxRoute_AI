<Window x:Class="FluxRoute.Views.AdminPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="FluxRoute"
        Height="240" Width="460"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStyle="None"
        AllowsTransparency="True">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="0" GlassFrameThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="#0C0F17" BorderBrush="#1C1F2E" BorderThickness="1" CornerRadius="12">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Требуются права администратора"
                       FontFamily="Segoe UI" Foreground="#E6EDF3" FontSize="15"
                       FontWeight="SemiBold" Margin="0,0,0,12"/>

            <!-- Description -->
            <TextBlock Grid.Row="1" TextWrapping="Wrap" FontFamily="Segoe UI"
                       Foreground="#E6EDF3" FontSize="13" Margin="0,0,0,8"
                       Text="Для корректной работы FluxRoute (запуск winws.exe, управление сетевыми фильтрами) необходимы права администратора."/>

            <TextBlock Grid.Row="2" TextWrapping="Wrap" FontFamily="Segoe UI"
                       Foreground="#8B949E" FontSize="12" VerticalAlignment="Center"
                       Text="Вы можете продолжить без прав, но функциональность будет ограничена."/>

            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Продолжить без прав" Click="ContinueButton_Click"
                        FontFamily="Segoe UI" Foreground="#8B949E" Background="Transparent"
                        BorderThickness="1" BorderBrush="#30363D"
                        Padding="16,8" FontSize="13" Cursor="Hand" Margin="0,0,10,0"
                        ToolTip="Продолжить работу в ограниченном режиме"
                        AutomationProperties.Name="Продолжить без прав администратора">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Border Background="{TemplateBinding Background}"/>
                                    <Border x:Name="HoverOverlay" Opacity="0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#161B22"/>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#4FC3F7"/>
                                    <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Content="Перезапустить с правами" Click="RestartAsAdminButton_Click"
                        FontFamily="Segoe UI" Foreground="#4FC3F7" Background="Transparent"
                        BorderThickness="1" BorderBrush="#264F78"
                        Padding="16,8" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                        ToolTip="Перезапустить приложение от имени администратора"
                        AutomationProperties.Name="Перезапустить с правами администратора">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Border Background="{TemplateBinding Background}"/>
                                    <Border x:Name="HoverOverlay" Opacity="0">
                                        <Border.Background>
                                            <SolidColorBrush Color="#161B22"/>
                                        </Border.Background>
                                    </Border>
                                    <ContentPresenter Margin="{TemplateBinding Padding}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.15">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.2">
                                                    <DoubleAnimation.EasingFunction>
                                                        <CubicEase EasingMode="EaseOut"/>
                                                    </DoubleAnimation.EasingFunction>
                                                </DoubleAnimation>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="#4FC3F7"/>
                                    <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
